# Slack Webhook URL (For DAILY reports only)
# The monitor generates a markdown report (GERRIT_DAILY_REPORT.md) by default
# For daily Slack notifications, uncomment and set this:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Get webhook URL from https://api.slack.com/messaging/webhooks

# Email Notification Settings (For WEEKLY reports only)
# To enable weekly email notifications, uncomment and configure these settings:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=your-email@gmail.com
# TO_EMAILS=a.nikhil@ibm.com,rajivs12@in.ibm.com
# Note: For Gmail, you need to use an App Password, not your regular password
# Generate one at: https://myaccount.google.com/apppasswords

# Optional: Override default configuration
# GERRIT_URL=https://gerrit.openbmc.org
# PROJECT=openbmc/webui-vue
# CHECK_DAYS=7